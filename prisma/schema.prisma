generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  orderId      String   @id
  value        Float
  creationDate DateTime
  items        Item[]
}

model Item {
  orderId   String
  productId Int
  quantity  Int
  price     Float
  order     Order  @relation(fields: [orderId], references: [orderId])

  @@id([orderId, productId])
}